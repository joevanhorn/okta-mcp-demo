# =============================================================================
# Okta MCP Adapter Demo — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Okta Configuration ---
OKTA_ORG_URL=https://YOUR-ORG.okta.com
OKTA_API_TOKEN=                          # SSWS token for API calls
OKTA_AUTH_SERVER_ID=                      # Custom auth server ID (aus...)

# --- Okta OIDC Apps ---
MCP_ADAPTER_CLIENT_ID=                   # MCP Adapter OIDC app client ID
MCP_ADAPTER_CLIENT_SECRET=               # MCP Adapter OIDC app client secret
ADMIN_UI_CLIENT_ID=                      # Admin UI OIDC app client ID
ADMIN_UI_CLIENT_SECRET=                  # Admin UI OIDC app client secret

# --- Salesforce ---
SFDC_CLIENT_ID=                          # Connected App client ID
SFDC_CLIENT_SECRET=                      # Connected App client secret
SFDC_INSTANCE_URL=https://YOUR-ORG.develop.my.salesforce.com

# --- ServiceNow ---
SNOW_INSTANCE_URL=https://YOUR-INSTANCE.service-now.com
SNOW_USERNAME=admin                      # Local admin user (NOT federated)
SNOW_PASSWORD=                           # ServiceNow admin password

# --- Okta FGA ---
FGA_API_URL=https://api.us1.fga.dev
FGA_STORE_ID=                            # From dashboard.fga.dev
FGA_MODEL_ID=                            # Set after running setup_fga.py
FGA_CLIENT_ID=                           # FGA API credentials
FGA_CLIENT_SECRET=                       # FGA API credentials

# --- AWS ---
AWS_REGION=us-east-2
AWS_PROFILE=                             # If using named profiles

# --- Adapter Admin ---
ADAPTER_ADMIN_PASSWORD=                  # Generated by Terraform (check state)

# --- Domain ---
DOMAIN=YOUR-DOMAIN                       # e.g., supersafe-ai.io
